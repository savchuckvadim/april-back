# ============================================================
# bot — переменные КОНКРЕТНОГО приложения (шаблон).
# Скопируйте в apps/bot/.env (реальный .env в gitignore).
#
# Назначение приложения: каналы общения с пользователями (Bitrix-бот и
# Telegram-бот). Знают сценарии и кнопки, собирают предданные и отправляют их
# в профильные приложения. Пока это рабочие шаблоны без полной бизнес-логики.
#
# Сюда — ТОЛЬКО специфика приложения (например, токены ботов). Общие секреты
# (DB/Redis/Bitrix) живут в корневом /.env (ConfigModule isGlobal).
#
# Порт НЕ задаём здесь:
#   • локально (nest start)  — defaultPort из main.ts (переопределить можно PORT=...)
#   • в Docker               — внутренний 3000 задаёт compose, внешний host-порт
#                              централизован в infra/compose/ports.env
# ============================================================
GLOBAL_PREFIX=api
SWAGGER_PATH=docs/api
SWAGGER_TITLE=bot API
SWAGGER_DESCRIPTION=API ботов общения с пользователями (bot)
SWAGGER_VERSION=1.0

# Токен Telegram-бота (заполнить реальным значением в apps/bot/.env)
TELEGRAM_BOT_TOKEN=
