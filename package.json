        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.3",
        "@types/jest": "^29.5.14",
        "@types/multer": "^1.4.13",
        "@types/node": "^22.10.7",
        "@types/nodemailer": "^7.0.2",
        "@types/pizzip": "^3.0.5",
        "@types/react": "^19.1.6",
        "@types/react-dom": "^19.1.5",
        "@types/supertest": "^6.0.2",
        "cross-env": "^7.0.3",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "jest": "^29.7.0",
        "madge": "^8.0.0",
        "prettier": "^3.4.2",
        "prisma": "^6.16.3",
        "react-email": "4.3.1",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0",
        "webpack": "^5.107.2"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "moduleNameMapper": {
            "^@lib/shared(|/.*)$": "<rootDir>/libs/shared/src/$1",
            "^@lib/core(|/.*)$": "<rootDir>/libs/core/src/$1",
            "^@lib/bitrix(|/.*)$": "<rootDir>/libs/bitrix/src/$1",
            "^@lib/pbx(|/.*)$": "<rootDir>/libs/pbx/src/$1",
            "^@lib/ai-rag(|/.*)$": "<rootDir>/libs/ai-rag/src/$1",
            "^@pbx$": "<rootDir>/libs/pbx/src/index.ts",
            "^(@/|src/)shared(|/.*)$": "<rootDir>/libs/shared/src/$2",
            "^(@/|src/)core(|/.*)$": "<rootDir>/libs/core/src/$2",
            "^(@/|src/)modules/bitrix(|/.*)$": "<rootDir>/libs/bitrix/src/$2",
            "^(@/|src/)modules/pbx(|/.*)$": "<rootDir>/libs/pbx/src/$2",
            "^(@/|src/)modules/ai-rag(|/.*)$": "<rootDir>/libs/ai-rag/src/$2",
            "^@apps/(.*)$": "<rootDir>/apps/back/src/apps/$1",
            "^@prisma$": "<rootDir>/generated/prisma/index.ts",
            "^generated/(.*)$": "<rootDir>/generated/$1",
            "^(@/|src/)(.*)$": "<rootDir>/apps/back/src/$2"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/apps/",
            "<rootDir>/libs/"
        ]
    }
}
