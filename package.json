    "scripts": {
        "build": "nest build back",
        "build:back": "nest build back",
        "build:kpi-report-sales": "nest build kpi-report-sales",
        "build:pbx-install": "nest build pbx-install",
        "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
        "start": "nest start back",
        "dev": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start back --watch",
        "dev:back": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start back --watch",
        "dev:kpi-report-sales": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start kpi-report-sales --watch",
        "dev:kpi-report-service": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start kpi-report-service --watch",
        "dev:pbx-install": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start pbx-install --watch",
        "dev:event-sales": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start event-sales --watch",
        "dev:event-service": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start event-service --watch",
        "dev:admin": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start admin --watch",
        "dev:all": "npm run dev:back & npm run dev:kpi-report-sales & npm run dev:pbx-install & npm run dev:event-sales & npm run dev:event-service & npm run dev:admin",

        "start:debug": "nest start back --debug --watch",
        "start:prod": "node dist/apps/back/main",
        "start:prod:back": "node dist/apps/back/main",
        "start:prod:kpi-report-sales": "node dist/apps/kpi-report-sales/main",
        "start:prod:pbx-install": "node dist/apps/pbx-install/main",
        "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./apps/back/test/jest-e2e.json",
        "key:generate": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"",
        "prisma:pull": "prisma db pull",
        "prisma:generate": "prisma generate",
        "prisma:studio": "prisma studio"
    },
