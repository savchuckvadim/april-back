# ============================================================
# Host-порты приложений монорепо (внешние порты на хосте).
# Внутри контейнеров ВСЕ apps слушают 3000 (контейнеры изолированы) — наружу
# отдаются порты ниже. Это НЕ секрет, файл коммитится (сервер берёт его из git).
#
# Подключается явно: docker compose --env-file ports.env -f <compose> ...
# (см. infra/README.md). Менять порт приложения → менять ТОЛЬКО здесь.
# ============================================================
# --- приложения (host-порт : 3000 внутри контейнера) ---
BACK_HOST_PORT=8334
KPI_REPORT_SALES_HOST_PORT=8335
PBX_INSTALL_HOST_PORT=8336
KPI_REPORT_SERVICE_HOST_PORT=8337
ADMIN_HOST_PORT=8338
EVENT_SALES_HOST_PORT=8339
EVENT_SERVICE_HOST_PORT=8340
KONSTRUCTOR_HOST_PORT=8341

# --- инфраструктура (host-порт : внутренний порт сервиса) ---
# Это порты ДОСТУПА С ХОСТА. Приложения внутри сети ходят на redis:6379 и
# gotenberg:3000 (имя сервиса + внутренний порт), а НЕ на эти host-порты.
REDIS_HOST_PORT=6334
GOTENBERG_HOST_PORT=33030
DB_HOST_PORT=3306
api.kpi-sales
api.kpi-service
api.event-sales
api.event-service
api.konstructor
api.back
api.admin
api.install
api.cabinet
