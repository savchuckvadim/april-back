{
  // ============================================================
  // Родительский tsconfig монорепозитория.
  // Наследуется ВСЕМИ приложениями (apps/*/tsconfig.app.json)
  // и библиотеками (libs/*/tsconfig.lib.json) через "extends".
  //
  // ВАЖНО: TypeScript НЕ сливает "paths" при extends — дочерний
  // конфиг полностью заменяет родительский. Поэтому все алиасы
  // путей держим централизованно ЗДЕСЬ (единый источник правды),
  // а дочерние конфиги своих "paths" не объявляют.
  // ============================================================
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "commonjs",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "paths": {
      // ---- Библиотеки (канонические алиасы, предпочтительны в новом коде) ----
      "@lib/shared": ["libs/shared/src"],
      "@lib/shared/*": ["libs/shared/src/*"],
      "@lib/core": ["libs/core/src"],
      "@lib/core/*": ["libs/core/src/*"],
      "@lib/bitrix": ["libs/bitrix/src"],
      "@lib/bitrix/*": ["libs/bitrix/src/*"],
      "@lib/pbx": ["libs/pbx/src"],
      "@lib/pbx/*": ["libs/pbx/src/*"],
      "@lib/ai-rag": ["libs/ai-rag/src"],
      "@lib/ai-rag/*": ["libs/ai-rag/src/*"],
      "@lib/bitrix-auth": ["libs/bitrix-auth/src"],
      "@lib/bitrix-auth/*": ["libs/bitrix-auth/src/*"],
      "@lib/online": ["libs/online/src"],
      "@lib/online/*": ["libs/online/src/*"],
      "@lib/telegram": ["libs/telegram/src"],
      "@lib/telegram/*": ["libs/telegram/src/*"],
      "@lib/garant": ["libs/garant/src"],
      "@lib/garant/*": ["libs/garant/src/*"],
      "@lib/bitrix-setup": ["libs/bitrix-setup/src"],
      "@lib/bitrix-setup/*": ["libs/bitrix-setup/src/*"],
      "@lib/queue": ["libs/queue/src"],
      "@lib/queue/*": ["libs/queue/src/*"],

      // ---- portal-lib: единая библиотека Portal (portal + store + pbx-domain + konstructor) ----
      // Канонический алиас. Старые @lib/portal, @lib/portal-konstructor,
      // @lib/pbx-domain, @/modules/pbx-domain полностью заменены на него.
      "@lib/portal-lib": ["libs/portal-lib/index.ts"],
      "@lib/portal-lib/portal": ["libs/portal-lib/portal/src"],
      "@lib/portal-lib/portal/*": ["libs/portal-lib/portal/src/*"],
      "@lib/portal-lib/konstructor": ["libs/portal-lib/konstructor/src"],
      "@lib/portal-lib/konstructor/*": ["libs/portal-lib/konstructor/src/*"],
      "@lib/portal-lib/pbx-domain": ["libs/portal-lib/pbx/domain/src"],
      "@lib/portal-lib/pbx-domain/*": ["libs/portal-lib/pbx/domain/src/*"],
      "@lib/portal-lib/store": ["libs/portal-lib/store"],
      "@lib/portal-lib/store/*": ["libs/portal-lib/store/*"],
      "@lib/portal-lib/*": ["libs/portal-lib/*"],

      // ---- Совместимость: старые импорты модулей -> новые библиотеки ----
      // (переходный слой, чтобы не править сотни импортов сразу;
      //  постепенно мигрируем на @lib/*)
      "@/shared": ["libs/shared/src"],
      "@/shared/*": ["libs/shared/src/*"],
      "src/shared": ["libs/shared/src"],
      "src/shared/*": ["libs/shared/src/*"],
      "@/core": ["libs/core/src"],
      "@/core/*": ["libs/core/src/*"],
      "src/core": ["libs/core/src"],
      "src/core/*": ["libs/core/src/*"],
      "@/modules/bitrix": ["libs/bitrix/src"],
      "@/modules/bitrix/*": ["libs/bitrix/src/*"],
      "src/modules/bitrix": ["libs/bitrix/src"],
      "src/modules/bitrix/*": ["libs/bitrix/src/*"],
      "@/modules/pbx": ["libs/pbx/src"],
      "@/modules/pbx/*": ["libs/pbx/src/*"],
      "src/modules/pbx": ["libs/pbx/src"],
      "src/modules/pbx/*": ["libs/pbx/src/*"],
      "@/modules/ai-rag": ["libs/ai-rag/src"],
      "@/modules/ai-rag/*": ["libs/ai-rag/src/*"],
      "src/modules/ai-rag": ["libs/ai-rag/src"],
      "src/modules/ai-rag/*": ["libs/ai-rag/src/*"],
      "@/modules/queue": ["libs/queue/src"],
      "@/modules/queue/*": ["libs/queue/src/*"],
      "src/modules/queue": ["libs/queue/src"],
      "src/modules/queue/*": ["libs/queue/src/*"],
      "@pbx": ["libs/pbx/src/index.ts"],

      // ---- Приложение pbx-install (apps/pbx-install/src/modules) ----
      // самодостаточные внутренние импорты приложения установки
      "@app/pbx-install": ["apps/pbx-install/src/modules"],
      "@app/pbx-install/*": ["apps/pbx-install/src/modules/*"],

      // ---- Совместимость: вынесенные приложения ----
      // back ещё импортирует общие DTO kpi-report (kpi-report-ork);
      // долг: вынести общие типы в библиотеку.
      "@/apps/kpi-report": ["apps/kpi-report-sales/src"],
      "@/apps/kpi-report/*": ["apps/kpi-report-sales/src/*"],
      "src/apps/kpi-report": ["apps/kpi-report-sales/src"],
      "src/apps/kpi-report/*": ["apps/kpi-report-sales/src/*"],

      // ---- Сгенерированный Prisma client ----
      "@prisma": ["./generated/prisma/index.ts"],
      "generated/*": ["./generated/*"],

      // ---- Приложение back (apps/back/src) ----
      // generic-алиасы; стоят последними, перекрываются специфичными выше
      "@/*": ["./apps/back/src/*"],
      "@apps/*": ["./apps/back/src/apps/*"],
      "src/*": ["./apps/back/src/*"]
    },
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
