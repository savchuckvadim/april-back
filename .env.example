# ============================================================
# ОБЩИЙ .env монорепо (шаблон). Скопируйте в `.env` и заполните значения.
# Эти переменные общие для ВСЕХ приложений (apps/*). Специфичные для одного
# приложения (PORT, SWAGGER_*) — кладите в apps/<app>/.env (см. .env.example там).
# Реальные .env закоммичены НЕ будут (см. .gitignore).
# ============================================================

# ---- Окружение ----
NODE_ENV=production
# PORT здесь НЕ задаём — он у каждого приложения свой (apps/<app>/.env / compose)

# ---- База данных (внешняя на проде; локально — контейнер db из compose) ----
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DBNAME
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_PASSWORD=

# ---- Redis (общий для координации rate-limit/кэша между приложениями) ----
REDIS_HOST=
REDIS_PORT=6379

# ---- Bitrix / интеграции ----
APP_NAME=
APP_URL=
APP_SECRET_KEY=
CORS_ORIGIN=
ADMIN=
CLIENT_CABINET=
CLIENT_CABINET_URL=
AUTH_COOKIE_SPA_DOMAIN=
BITRIX_RATE_LIMIT_ENABLED=true
BITRIX_VIBE_TEST=
MISSED_CALLS_PORTAL_DOMAIN=

# placement-коды приложений Bitrix
EVENT_SALES_PLACEMENT=
EVENT_SERVICE_PLACEMENT=
KONSTRUCTOR_PLACEMENT=
REPORT_SALES_PLACEMENT=
REPORT_SERVICE_PLACEMENT=

# ---- API online ----
API_ONLINE_URL=
API_ONLINE_KEY=
API_ONLINE_ADMIN_URL=

# ---- LibreOffice / Gotenberg ----
LIBREOFFICE_MODE=
LIBREOFFICE_HTTP_URL=

# ---- Почта ----
MAIL_HOST=
MAIL_PORT=
MAIL_LOGIN=
MAIL_PASSWORD=

# ---- Telegram (опционально; фильтр уведомлений работает и без бота) ----
WITH_TELEGRAM=false
WITH_SCHEDLER=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_CHAT_BOT_TOKEN=
TELEGRAM_CHAT_MANAGER_CHAT_ID=
TELEGRAM_BRIDGE_WEBHOOK_URL=
BITRIX_IM_BRIDGE_DOMAINS=
BITRIX_IM_BRIDGE_IGNORE_BOTS=
BITRIX_IM_BRIDGE_IGNORE_SYSTEM=
BITRIX_IM_BRIDGE_POLL_LIMIT=
BITRIX_IM_BRIDGE_PORTAL_DENYLIST=
BITRIX_IM_BRIDGE_PORTAL_WHITELIST=
BITRIX_IM_BRIDGE_USER_EMAIL=

# ---- Yandex Object Storage (S3) ----
YA_ACCESS_KEY_ACCOUNT_ID=
YA_ACCESS_KEY_ID=
YA_ACCESS_KEY_KEY_ID=
YA_ACCESS_KEY_SECRET=
YA_BUCKET_NAME=
YA_FOLDER_ID=
YA_OAUTH=

# ---- Деплой (используется docker-compose.prod.yml) ----
GHCR_OWNER=
IMAGE_TAG=latest
